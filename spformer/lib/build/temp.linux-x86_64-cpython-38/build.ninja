ninja_required_version = 1.3
cxx = g++-9
nvcc = /usr/local/cuda-11.4/bin/nvcc

cflags = -Wsign-compare -DNDEBUG -g -fwrapv -O3 -Wall -Wstrict-prototypes -fPIC -DWITH_CUDA -I/home/asus/miniconda3/envs/spformer/lib/python3.8/site-packages/torch/include -I/home/asus/miniconda3/envs/spformer/lib/python3.8/site-packages/torch/include/torch/csrc/api/include -I/home/asus/miniconda3/envs/spformer/lib/python3.8/site-packages/torch/include/TH -I/home/asus/miniconda3/envs/spformer/lib/python3.8/site-packages/torch/include/THC -I/usr/local/cuda-11.4/include -I/home/asus/miniconda3/envs/spformer/include/python3.8 -c
post_cflags = -g -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=pointgroup_ops_ext -D_GLIBCXX_USE_CXX11_ABI=0 -std=c++14
cuda_cflags = -DWITH_CUDA -I/home/asus/miniconda3/envs/spformer/lib/python3.8/site-packages/torch/include -I/home/asus/miniconda3/envs/spformer/lib/python3.8/site-packages/torch/include/torch/csrc/api/include -I/home/asus/miniconda3/envs/spformer/lib/python3.8/site-packages/torch/include/TH -I/home/asus/miniconda3/envs/spformer/lib/python3.8/site-packages/torch/include/THC -I/usr/local/cuda-11.4/include -I/home/asus/miniconda3/envs/spformer/include/python3.8 -c
cuda_post_cflags = -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr --compiler-options ''"'"'-fPIC'"'"'' -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=pointgroup_ops_ext -D_GLIBCXX_USE_CXX11_ABI=0 -gencode=arch=compute_86,code=compute_86 -gencode=arch=compute_86,code=sm_86 -ccbin gcc-9 -std=c++14
ldflags = 

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc  $cuda_cflags -c $in -o $out $cuda_post_cflags



